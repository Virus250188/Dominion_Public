generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             Int              @id @default(autoincrement())
  username       String           @unique
  email          String?
  password       String
  avatar         String?
  isAdmin        Boolean          @default(false)
  isPublic       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tiles          Tile[]
  settings       UserSettings?
  groups         TileGroup[]
  subDashboards  SubDashboard[]
  appConnections AppConnection[]
}

model Tile {
  id             Int         @id @default(autoincrement())
  title          String
  url            String
  color          String      @default("#6366f1")
  icon           String?
  customIconSvg  String?
  description    String?
  pinned         Boolean     @default(false)
  order          Int         @default(0)
  columnSpan     Int         @default(1)
  rowSpan        Int         @default(1)
  type           String      @default("standard")
  enhancedType   String?
  enhancedConfig String?
  appConnectionId Int?
  appConnection   AppConnection? @relation(fields: [appConnectionId], references: [id], onDelete: SetNull)
  groupId        Int?
  group          TileGroup?  @relation(fields: [groupId], references: [id])
  subDashboardId Int?
  subDashboard   SubDashboard? @relation("SubDashboardTiles", fields: [subDashboardId], references: [id])
  userId         Int
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupTiles     GroupTile[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([groupId])
  @@index([subDashboardId])
  @@index([appConnectionId])
}

model TileGroup {
  id             Int           @id @default(autoincrement())
  title          String
  icon           String?
  color          String        @default("#6366f1")
  order          Int           @default(0)
  collapsed      Boolean       @default(false)
  userId         Int           @default(1)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tiles          Tile[]
  groupTiles     GroupTile[]
  subDashboardId Int?
  subDashboard   SubDashboard? @relation("SubDashboardGroups", fields: [subDashboardId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([subDashboardId])
}

model GroupTile {
  id         Int       @id @default(autoincrement())
  groupId    Int
  tileId     Int
  order      Int       @default(0)
  columnSpan Int?
  rowSpan    Int?
  group      TileGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tile       Tile      @relation(fields: [tileId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([groupId, tileId])
  @@index([groupId])
  @@index([tileId])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
  type  String @default("string")
}

model UserSettings {
  id             Int     @id @default(autoincrement())
  userId         Int     @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme          String  @default("glass-dark")
  background     String?
  backgroundType String  @default("gradient")
  searchProvider String  @default("google")
  language       String  @default("de")
  gridColumns    Int     @default(6)
  tileSize       String  @default("medium")
  showSearch     Boolean @default(true)
  showClock      Boolean @default(true)
  showGreeting   Boolean @default(true)
  aiProvider     String?
  aiApiKey       String?
  aiModel        String?
  aiEndpoint     String?
}

model FoundationApp {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  icon        String
  color       String
  website     String?
  description String?
  category    String?
  enhanced    Boolean @default(false)
}

model SearchProvider {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  url       String
  icon      String?
  isDefault Boolean @default(false)
}

model SubDashboard {
  id          Int         @id @default(autoincrement())
  title       String
  icon        String?
  color       String      @default("#6366f1")
  description String?
  order       Int         @default(0)
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tiles       Tile[]      @relation("SubDashboardTiles")
  groups      TileGroup[] @relation("SubDashboardGroups")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
}

model HealthStatus {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  isOnline  Boolean  @default(false)
  lastCheck DateTime @default(now())
  latencyMs Int?

  @@index([url])
}

model AppConnection {
  id            Int      @id @default(autoincrement())
  userId        Int
  pluginType    String
  name          String
  icon          String?
  customIconSvg String?
  color         String   @default("#3b82f6")
  url           String?
  config        String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tiles Tile[]

  @@index([userId])
  @@index([pluginType])
}
